# Production hardening overrides for FrostGate Core
#
# This file is committed to git.
# It MUST NOT contain secrets. Secrets are injected by the deployment
# secret manager (e.g., Vault, AWS Secrets Manager, Kubernetes secrets).
#
# Docker Compose loads this file AFTER .env, so values here take precedence
# for any var set in both files.
#
# PRODUCTION OPERATOR CHECKLIST:
#   The following OIDC vars MUST be supplied via secret manager / deployment
#   env injection at runtime. They are NOT set in this file:
#     - FG_OIDC_ISSUER
#     - FG_OIDC_CLIENT_ID
#     - FG_OIDC_CLIENT_SECRET
#     - FG_OIDC_REDIRECT_URL
#     - FG_OIDC_SCOPES
#   Admin-gateway will refuse to boot in prod mode without these.

# ---------------------------------------------------------------------------
# DoS hardening (required — prod-profile-check enforces all of these)
# ---------------------------------------------------------------------------
FG_DOS_GUARD_ENABLED=true

# Request / body size limits
FG_MAX_BODY_BYTES=10485760
FG_MAX_QUERY_BYTES=8192
FG_MAX_PATH_BYTES=2048

# Header limits
FG_MAX_HEADERS_COUNT=64
FG_MAX_HEADERS_BYTES=32768
FG_MAX_HEADER_LINE_BYTES=8192

# Multipart limits
FG_MULTIPART_MAX_BYTES=104857600
FG_MULTIPART_MAX_PARTS=32

# Timeout / concurrency
FG_REQUEST_TIMEOUT_SEC=30
FG_KEEPALIVE_TIMEOUT_SEC=75
FG_MAX_CONCURRENT_REQUESTS=500

# Rate-limiting: must be fail-closed in production (also enforced inline in compose)
FG_RL_FAIL_OPEN=false
