# FrostGate production profile defaults for compose/gates.
# Non-secret hardening defaults only. Runtime secrets must still come from .env/CI secrets.

FG_ENV=prod
FG_DEBUG=false
FG_LOG_LEVEL=info
FG_AUTH_ALLOW_FALLBACK=false

# DoS and request hardening (must be explicit in production profile gate)
FG_DOS_GUARD_ENABLED=true
FG_MAX_BODY_BYTES=1048576
FG_MAX_QUERY_BYTES=8192
FG_MAX_PATH_BYTES=4096
FG_MAX_HEADERS_COUNT=100
FG_MAX_HEADERS_BYTES=16384
FG_MAX_HEADER_LINE_BYTES=8192
FG_MULTIPART_MAX_BYTES=10485760
FG_MULTIPART_MAX_PARTS=32
FG_REQUEST_TIMEOUT_SEC=30
FG_KEEPALIVE_TIMEOUT_SEC=5
FG_MAX_CONCURRENT_REQUESTS=200
FG_RL_FAIL_OPEN=false
