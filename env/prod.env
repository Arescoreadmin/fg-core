# Production overrides
FG_ENV=prod
FG_DEBUG=false
FG_LOG_LEVEL=info
FG_ENFORCEMENT_MODE=enforce

# ----------------------------
# Postgres production contract
# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=postgres
POSTGRES_APP_USER=fg_user
POSTGRES_APP_PASSWORD=CHANGE_ME_POSTGRES_APP_PASSWORD
POSTGRES_APP_DB=frostgate

FG_DB_BACKEND=postgres
FG_DB_URL=postgresql+psycopg://fg_user:CHANGE_ME_POSTGRES_APP_PASSWORD@postgres:5432/frostgate
DATABASE_URL=postgresql+psycopg://fg_user:CHANGE_ME_POSTGRES_APP_PASSWORD@postgres:5432/frostgate
FG_DB_MIGRATIONS_REQUIRED=1
FG_DB_MIGRATIONS_RISK_ACCEPTED=0

# ----------------------------
# OIDC / Identity Provider
# Set FG_OIDC_* directly OR set FG_KEYCLOAK_* to derive from Keycloak.
# For Keycloak (bundled fg-idp profile):
#   FG_KEYCLOAK_BASE_URL=http://fg-idp.local:8081
#   FG_KEYCLOAK_REALM=FrostGate
#   FG_KEYCLOAK_CLIENT_ID=fg-admin
#   FG_KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET
# For external OIDC (Azure AD, Okta, etc.):
#   FG_OIDC_ISSUER=https://login.microsoftonline.com/TENANT_ID/v2.0
#   FG_OIDC_CLIENT_ID=CHANGE_ME_OIDC_CLIENT_ID
#   FG_OIDC_CLIENT_SECRET=CHANGE_ME_OIDC_CLIENT_SECRET
#   FG_OIDC_REDIRECT_URL=https://YOUR_ADMIN_HOST/auth/callback
# ----------------------------
FG_OIDC_SCOPES="openid profile email"
FG_KEYCLOAK_BASE_URL=CHANGE_ME_KEYCLOAK_BASE_URL
FG_KEYCLOAK_REALM=FrostGate
FG_KEYCLOAK_CLIENT_ID=fg-admin
FG_KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET
FG_OIDC_REDIRECT_URL=CHANGE_ME_OIDC_REDIRECT_URL
FG_AUTH_ALLOW_FALLBACK=false

# ----------------------------
# OPA / policy
# ----------------------------
FG_OPA_URL=http://opa:8181
FG_OPA_ENFORCE=1
FG_OPA_RISK_ACCEPTED=0

# ----------------------------
# Redis / NATS production
# ----------------------------
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
FG_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

NATS_AUTH_TOKEN=CHANGE_ME_NATS_AUTH_TOKEN
FG_NATS_URL=nats://CHANGE_ME_NATS_AUTH_TOKEN@nats:4222
FG_NATS_ENABLED=1
FG_NATS_RISK_ACCEPTED=0

# ----------------------------
# Production platform flags
# ----------------------------
FG_GOVERNANCE_ENABLED=1
FG_ROE_ENGINE_ENABLED=1
FG_RING_ROUTER_ENABLED=1
FG_MISSION_ENVELOPE_ENABLED=1

FG_MISSION_ENVELOPE_PATH=/var/lib/frostgate/mission/envelope.json
FG_RING_STATE_DIR=/var/lib/frostgate/ring/state
FG_RING_MODEL_DIR=/var/lib/frostgate/ring/models

# ----------------------------
# Production security / limits
# ----------------------------
FG_DOS_GUARD_ENABLED=true
FG_MAX_BODY_BYTES=4194304
FG_MAX_QUERY_BYTES=8192
FG_MAX_PATH_BYTES=2048
FG_MAX_HEADERS_COUNT=50
FG_MAX_HEADERS_BYTES=16384
FG_MAX_HEADER_LINE_BYTES=8192
FG_MULTIPART_MAX_BYTES=10485760
FG_MULTIPART_MAX_PARTS=20
FG_REQUEST_TIMEOUT_SEC=30
FG_KEEPALIVE_TIMEOUT_SEC=65
FG_MAX_CONCURRENT_REQUESTS=200
FG_RL_FAIL_OPEN=false

# ----------------------------
# Production secrets — rotate externally before deploy
# All values below must be replaced via your secrets manager before use.
# Run: make rotate-prod-secrets  (generates and injects via Vault/AWS SSM)
# ----------------------------
FG_SIGNING_SECRET=CHANGE_ME_FG_SIGNING_SECRET
FG_INTERNAL_AUTH_SECRET=CHANGE_ME_FG_INTERNAL_AUTH_SECRET
FG_API_KEY=CHANGE_ME_FG_API_KEY
FG_AGENT_API_KEY=CHANGE_ME_FG_AGENT_API_KEY
FG_WEBHOOK_SECRET=CHANGE_ME_FG_WEBHOOK_SECRET
FG_SESSION_SECRET=CHANGE_ME_FG_SESSION_SECRET
FG_ENCRYPTION_KEY=CHANGE_ME_FG_ENCRYPTION_KEY
FG_JWT_SECRET=CHANGE_ME_FG_JWT_SECRET

# ----------------------------
# CORS
# ----------------------------
FG_CORS_ORIGINS=http://fg-admin.local:13000,http://fg-admin.local:18080
AG_CORS_ORIGINS=http://fg-admin.local:13000,http://localhost:13000
AG_AUDIT_ENABLED=true

# ----------------------------
# Dev bypass remains off
# ----------------------------
FG_DEV_AUTH_BYPASS=0
FG_DEV_TENANT_ID=default
FG_DEV_ALLOWED_TENANTS=default
