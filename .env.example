# FrostGate Core — Environment Variable Reference
#
# Copy this file to .env and fill in values for your environment.
# Never commit .env or env/prod.env — they contain real credentials.
#
# Required vars are marked [REQUIRED]. Everything else has a safe default
# that works in development but must be explicitly set for production.
#
# Grouped by service. For architecture context see SYSTEM.md.
# For client readiness gaps see ROADMAP.md Phase 2.

# ─── fg-core API ──────────────────────────────────────────────────────────────

# Runtime environment: development | staging | production
FG_ENV=development

# Auth — set FG_AUTH_ENABLED=1 and a strong FG_API_KEY in staging/production.
# In development (FG_AUTH_ENABLED=0) no API key is required.
FG_AUTH_ENABLED=0
FG_API_KEY=                              # [REQUIRED in production] min 32 chars, random

# Database — PostgreSQL is required for production.
# If FG_DB_URL is not set, falls back to SQLite at FG_SQLITE_PATH (dev only).
FG_DB_URL=postgresql://frostgate:password@localhost:5432/frostgate
FG_DB_BACKEND=postgres                   # postgres | sqlite
FG_SQLITE_PATH=state/frostgate.db        # used only when FG_DB_BACKEND=sqlite

# Redis — required for production rate limiting and session state.
FG_REDIS_URL=redis://localhost:6379
FG_RL_ENABLED=true
FG_RL_BACKEND=redis                      # redis | memory (memory only for dev/test)

# NATS JetStream — async event bus. Disable in dev unless testing event flows.
FG_NATS_ENABLED=false
FG_NATS_URL=nats://localhost:4222

# OPA policy engine
FG_OPA_ENFORCE=false                     # set true when OPA container is running

# Logging and observability
FG_LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
FG_OBSERVABILITY_MODE=local              # local | otel
FG_OTEL_ENABLED=false
FG_OTEL_ENDPOINT=http://localhost:4317
FG_OTEL_SAMPLE_RATE=1.0

# Security — HMAC and signing keys. Generate with: openssl rand -hex 32
FG_KEY_PEPPER=                           # [REQUIRED in production] 32+ char random string
FG_BILLING_EVIDENCE_HMAC_KEY=            # [REQUIRED in production] 32+ char random string
FG_CONTROL_TOWER_SIGNING_SECRET=         # [REQUIRED in production] 32+ char random string
FG_INTERNAL_AUTH_SECRET=                 # [REQUIRED in production] for internal service calls

# Tenant context
FG_TENANT_CONTEXT_MODE=db_session        # db_session | app_only

# ─── AI Providers ─────────────────────────────────────────────────────────────

# Anthropic — used for report generation and finding explanations.
FG_ANTHROPIC_API_KEY=sk-ant-...          # [REQUIRED] for any AI report/explain feature
FG_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
FG_ANTHROPIC_TIMEOUT_SECONDS=60
FG_AI_PLANE_ENABLED=1
FG_AI_DEFAULT_PROVIDER=anthropic
FG_AI_EXTERNAL_PROVIDER_ENABLED=true

# Azure OpenAI — optional alternative provider.
FG_AZURE_OPENAI_ENDPOINT=
FG_AZURE_OPENAI_DEPLOYMENT=
FG_AZURE_AI_KEY=
FG_AZURE_OPENAI_MODEL=
FG_AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Field Assessment ─────────────────────────────────────────────────────────

# Connector acknowledgment key — symmetric key for scan result import signing.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# WARNING: if this is missing, all connector imports will silently fail.
FG_ACKNOWLEDGMENT_KEY=                   # [REQUIRED] for MS Graph and any connector import

# MS Graph / Azure AD — required to run Microsoft 365 NIST AI RMF scans.
# Register an Azure AD app with these API permissions (application, admin consent required):
#   Directory.Read.All, User.Read.All, Policy.Read.All,
#   AuditLog.Read.All, Reports.Read.All, RoleManagement.Read.Directory
# The scan uses device-code flow — operator completes browser auth once per session.
FG_MSAL_CLIENT_ID=                       # [REQUIRED] Azure AD app (client) ID for MS Graph scans

# Report verification URL — embedded in client-delivered reports.
# Must point to your deployed portal or verification endpoint.
FG_REPORT_VERIFY_URL=http://localhost:3001/verify

# ─── Portal BFF (apps/portal) ─────────────────────────────────────────────────
#
# Per-tenant client-facing Next.js app.
# Each client deployment gets its own CORE_TENANT_ID.
# The BFF proxy at /api/core injects X-Tenant-ID server-side.

CORE_API_URL=http://localhost:8080       # [REQUIRED] fg-core API base URL
CORE_API_KEY=                            # [REQUIRED] matches FG_API_KEY in fg-core
CORE_TENANT_ID=                          # [REQUIRED] tenant UUID for this portal deployment

# Portal rate limiting (back with Redis for multi-node prod)
PORTAL_RL_MAX_REQUESTS=100
PORTAL_RL_WINDOW_MS=60000

# ─── Console BFF (apps/console) ───────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8080
BFF_REDIS_URL=redis://localhost:6379
BFF_RATE_LIMIT_BACKEND=memory            # memory | redis
BFF_RATE_LIMIT_MAX_REQUESTS=200
BFF_RATE_LIMIT_WINDOW_S=60

# ─── Payments (Tier 1 — assessment funnel) ────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Alerting (optional) ──────────────────────────────────────────────────────

FG_ALERT_BACKEND=                        # opsgenie | pagerduty | webhook | (empty = disabled)
FG_OPSGENIE_API_KEY=
FG_PAGERDUTY_ROUTING_KEY=
FG_ALERT_WEBHOOK_URL=

# ─── Development / test only ──────────────────────────────────────────────────

# Enables POST /dev/seed. Never set in production.
FG_DEV_EVENTS_ENABLED=0
