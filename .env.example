# FrostGate environment configuration
# Copy this file to .env and adjust as needed

# Database (POSTGRES_PASSWORD required - no default for security)
POSTGRES_USER=fg_user
POSTGRES_PASSWORD=
POSTGRES_DB=frostgate

# Redis (required - no default for security)
REDIS_PASSWORD=

# NATS (required for ingestion bus in prod)
NATS_AUTH_TOKEN=
FG_NATS_URL=
FG_NATS_ENABLED=0
FG_NATS_RISK_ACCEPTED=0

# API Keys (use FG_API_KEYS_FILE in production)
# Format: 32+ chars, random (avoid dictionary words)
FG_API_KEY=
# Dedicated internal credential for Admin-Gateway -> Core /admin calls in prod/staging
FG_ADMIN_GATEWAY_INTERNAL_TOKEN=

# Encryption / JWT (required in prod)
# Format: 32+ chars, random (base64 ok)
FG_ENCRYPTION_KEY=
FG_JWT_SECRET=

# Webhook signing (required in prod)
# Format: 32+ chars, random
FG_WEBHOOK_SECRET=

# Environment
FG_ENV=dev
FG_DEBUG=false
FG_LOG_LEVEL=info
FG_DB_BACKEND=postgres
FG_DB_URL=
FG_DB_MIGRATIONS_REQUIRED=1
FG_DB_MIGRATIONS_RISK_ACCEPTED=0

# CORS (no wildcard; comma-separated origins)
FG_CORS_ORIGINS=https://example.com

# UI kill-switch (prod/staging default is disabled if unset)
FG_UI_ENABLED=0

# Admin Gateway (use with docker compose --profile admin)
# CORS: explicit origins required
AG_CORS_ORIGINS=http://localhost:13000
AG_AUDIT_ENABLED=true
# Dedicated outbound credential Admin-Gateway uses for Core /admin calls in prod/staging
AG_CORE_INTERNAL_TOKEN=

# Console (use with docker compose --profile admin)
# NEXT_PUBLIC_API_URL is set automatically in docker-compose

# Compliance-critical modules (must be enabled in prod/staging)
FG_GOVERNANCE_ENABLED=1
FG_ROE_ENGINE_ENABLED=1
FG_RING_ROUTER_ENABLED=1
FG_MISSION_ENVELOPE_ENABLED=1

# Policy enforcement (OPA)
FG_OPA_URL=http://localhost:18181
FG_OPA_ENFORCE=1
FG_OPA_RISK_ACCEPTED=0

# Compliance-critical resources (required when modules enabled in prod/staging)
FG_MISSION_ENVELOPE_PATH=/etc/frostgate/mission_envelope.json
FG_RING_STATE_DIR=/var/lib/frostgate/state
FG_RING_MODEL_DIR=/var/lib/frostgate/models

# -- Revenue + AI provider (REQUIRED in prod/staging before accepting payments) --
#
# STRIPE_SECRET_KEY     - Stripe secret key (sk_live_* in production).
#                         Required to initiate Stripe Checkout sessions.
#                         Do NOT commit real keys. Use sk_test_* for local dev only.
# STRIPE_WEBHOOK_SECRET - Stripe webhook signing secret (whsec_*).
#                         Required to verify Stripe event HMAC signatures.
#                         Without this, all Stripe webhook events are unauthenticated.
# FG_ANTHROPIC_API_KEY  - Anthropic API key for AI report generation.
#                         Required to generate executive/technical/compliance reports.
#                         Without this, report generation fails at runtime.
#
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FG_ANTHROPIC_API_KEY=
