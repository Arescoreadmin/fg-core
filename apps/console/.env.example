# Console BFF environment variables — copy to .env.local and fill in values
# NEVER prefix rate-limit or Redis config with NEXT_PUBLIC_ — these are server-only.

# ─── Core API proxy (existing) ───────────────────────────────────────────────
CORE_API_URL=http://localhost:8000
CORE_API_KEY=
CORE_TENANT_ID=

# ─── Demo tenant routing (optional) ─────────────────────────────────────────
# Comma-separated tenant IDs that may be selected with ?tenant_id=... in the
# console BFF. Each selected tenant must have a matching tenant-bound API key.
FG_CONSOLE_DEMO_TENANTS=
# JSON object: {"demo-bank":"fgk...","demo-healthcare":"fgk..."}
FG_CONSOLE_DEMO_TENANT_KEYS=
# Shared alternative read by console and portal when app-specific vars are unset.
FG_DEMO_TENANT_API_KEYS=

# ─── Console Auth Session Policy ────────────────────────────────────────────
# Local Auth.js session lifetime. Closing the browser window is not treated as
# logout; these values control how long a closed/reopened browser can reuse the
# local console session before requiring a fresh Auth0 login.
AUTH_SESSION_MAX_AGE_SECONDS=28800
AUTH_SESSION_UPDATE_AGE_SECONDS=900

# Console/site origin used for server-side absolute BFF fetches and logout return URLs.
CONSOLE_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth0 issuer origin added to CSP connect-src and used for federated logout.
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_ROLES_CLAIM=https://frostgate.ai/roles
# AUTH0_TENANT_ID_CLAIM=https://frostgate.ai/tenant_id
# FG_CONSOLE_ALLOW_LEGACY_INTERNAL_FALLBACK=false
# NEXT_PUBLIC_API_URL=http://localhost:18001


# ─── BFF Redis Rate-Limit (PR 8 / PR 9) ─────────────────────────────────────
# Redis/Upstash config for BFF rate-limit storage (server-only; never NEXT_PUBLIC_).
#
# PRODUCTION / STAGING: Redis or Upstash REST config is REQUIRED.
#   - If missing, blank, or still set to a CHANGE_ME placeholder, the BFF
#     will return 503 BFF_RATE_LIMIT_REDIS_CONFIG_REQUIRED on every /api/core request.
#   - If the config is valid but the store is unreachable, the BFF will return
#     503 BFF_RATE_LIMIT_REDIS_UNAVAILABLE (fail-closed — no silent pass-through).
#   - Memory fallback is NOT available in production or staging.
#
# Redis protocol options (ioredis):
#   - BFF_REDIS_URL is preferred.
#   - REDIS_URL is accepted as a Vercel/Railway alias.
BFF_REDIS_URL=redis://:yourpassword@localhost:6379/1
# REDIS_URL=redis://:yourpassword@localhost:6379/1

# Upstash/Vercel KV REST options:
#   - UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN are accepted.
#   - KV_REST_API_URL + KV_REST_API_TOKEN are accepted for Vercel KV.
#   - BFF_UPSTASH_REDIS_REST_* may be used if you want BFF-specific names.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# DEVELOPMENT / TEST: Redis/Upstash config is optional.
#   - If unset, an in-process memory store is used automatically (not suitable
#     for production — does not survive restarts or scale across instances).
#   - If set but unreachable, falls back to memory (deterministic).

# Explicit backend override: "redis", "upstash-rest", or "memory".
# Default: "upstash-rest" when REST envs are set, "redis" when BFF_REDIS_URL/REDIS_URL is set, "memory" otherwise.
# WARNING: BFF_RATE_LIMIT_BACKEND=memory is rejected in production/staging —
#   the BFF will return 503 BFF_RATE_LIMIT_REDIS_CONFIG_REQUIRED.
BFF_RATE_LIMIT_BACKEND=redis

# Rate-limit window in seconds (default: 60)
BFF_RATE_LIMIT_WINDOW_S=60

# Maximum requests per window per tenant/user key (default: 100)
BFF_RATE_LIMIT_MAX_REQUESTS=100

# ─── FrostGate environment flag (used for dev/test fallback gating) ───────────
# Values: dev | development | local | test | prod | staging | production
# prod / staging / production → Redis config is required; memory fallback disabled.
# dev / development / local / test → memory fallback available.
FG_ENV=dev
