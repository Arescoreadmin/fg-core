# Portal BFF environment variables - copy to .env.local and fill in values
# Never expose these as NEXT_PUBLIC_* unless explicitly marked public.

CORE_API_URL=http://localhost:8000
CORE_API_KEY=
CORE_TENANT_ID=
PORTAL_SESSION_SECRET=

# Optional demo tenant routing. Portal sessions remain tenant-bound; this only
# lets the login page select one of the server-approved demo tenants.
FG_PORTAL_DEMO_TENANTS=
# JSON object: {"demo-bank":"fgk...","demo-healthcare":"fgk..."}
FG_PORTAL_DEMO_TENANT_KEYS=
# Shared alternative read by console and portal when app-specific vars are unset.
FG_DEMO_TENANT_API_KEYS=

# Public selector list rendered on the portal login page. Keep it in sync with
# FG_PORTAL_DEMO_TENANTS; it contains tenant IDs only, not secrets.
NEXT_PUBLIC_PORTAL_DEMO_TENANTS=

PORTAL_RL_WINDOW_MS=60000
PORTAL_RL_MAX_REQUESTS=60
