# Portal environment variables — copy to .env.local and fill in values

# ─── Backend API ─────────────────────────────────────────────────────────────
CORE_API_URL=http://localhost:8000
CORE_API_KEY=
CORE_TENANT_ID=

# ─── Portal auth ─────────────────────────────────────────────────────────────
# Password clients use on the /login page
PORTAL_PASSWORD=

# Secret for HMAC-SHA256 session cookies — generate with:
#   openssl rand -base64 32
PORTAL_SESSION_SECRET=

# ─── Rate limiting (in-memory; replace with Redis for multi-node) ─────────────
# Window in milliseconds (default: 60000)
PORTAL_RL_WINDOW_MS=60000
# Max requests per window per IP (default: 60)
PORTAL_RL_MAX_REQUESTS=60
