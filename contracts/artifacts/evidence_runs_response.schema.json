{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frostgate/contracts/artifacts/evidence_runs_response.schema.json",
  "title": "Evidence Runs Response",
  "description": "Canonical response schema for listing evidence runs across planes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "runs"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },

    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "plane_id",
          "artifact_type",
          "artifact_path",
          "status",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9._:-]+$"
          },

          "plane_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },

          "artifact_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },

          "artifact_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },

          "artifact_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },

          "schema_version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          },

          "git_sha": {
            "type": "string",
            "pattern": "^[a-f0-9]{7,64}$"
          },

          "created_at": {
            "type": "string",
            "format": "date-time"
          },

          "status": {
            "type": "string",
            "enum": [
              "created",
              "processing",
              "validated",
              "anchored",
              "failed",
              "expired"
            ]
          },

          "summary_json": {
            "type": ["object", "null"]
          },

          "retention_class": {
            "type": "string",
            "enum": [
              "standard",
              "elevated",
              "legal_hold",
              "permanent"
            ]
          },

          "anchor_status": {
            "type": "string",
            "enum": [
              "not_applicable",
              "pending",
              "anchored",
              "failed"
            ]
          }
        }
      }
    },

    "next_cursor": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256
    },

    "total_count": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  }
}