{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frostgate/contracts/artifacts/ai_plane_evidence.schema.json",
  "title": "AI Plane Evidence Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plane_id",
    "git_sha",
    "timestamp",
    "feature_flag_snapshot",
    "total_inference_calls",
    "total_blocked_calls",
    "total_policy_violations",
    "simulated_mode",
    "route_snapshot"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },

    "plane_id": {
      "type": "string",
      "const": "ai"
    },

    "git_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,64}$"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time"
    },

    "feature_flag_snapshot": {
      "type": "object",
      "additionalProperties": {
        "type": ["boolean", "string", "number"]
      }
    },

    "total_inference_calls": {
      "type": "integer",
      "minimum": 0
    },

    "total_blocked_calls": {
      "type": "integer",
      "minimum": 0
    },

    "total_policy_violations": {
      "type": "integer",
      "minimum": 0
    },

    "simulated_mode": {
      "type": "boolean",
      "const": true
    },

    "route_snapshot": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^/ai/"
      }
    }
  }
}