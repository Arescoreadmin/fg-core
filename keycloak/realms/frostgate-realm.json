{
  "realm": "FrostGate",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "fg-service",
      "name": "FrostGate Service Account",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "fg-service-ci-secret",
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "fg-scopes-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "fg_scopes",
            "claim.value": "[\"console:admin\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "access.tokenResponse.claim": "false"
          }
        },
        {
          "name": "fg-service-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fg-service",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "fg-tester",
      "name": "FrostGate Tester (canonical human tester identity)",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "fg-tester-ci-secret",
      "serviceAccountsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "fg-tester-allowed-tenants-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "allowed_tenants",
            "claim.value": "[\"tenant-seed-primary\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "access.tokenResponse.claim": "false"
          }
        },
        {
          "name": "fg-tester-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fg-tester",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "fg-tester-admin",
      "enabled": true,
      "emailVerified": true,
      "email": "fg-tester-admin@frostgate.local",
      "credentials": [
        {
          "type": "password",
          "value": "fg-tester-password",
          "temporary": false
        }
      ],
      "realmRoles": ["frostgate-admin"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "frostgate-admin",
        "description": "FrostGate administrator role"
      },
      {
        "name": "auditor",
        "description": "FrostGate read-only auditor role"
      }
    ]
  },
  "scopeMappings": [],
  "clientScopeMappings": {}
}
