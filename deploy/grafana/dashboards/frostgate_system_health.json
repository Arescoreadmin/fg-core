{
  "__requires": [{"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"}],
  "annotations": {"list": []},
  "description": "FrostGate system health: request rates, error rates, latency, and infrastructure",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Request Traffic",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Request Rate (req/s)",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource"}, "expr": "sum(rate(frostgate_http_request_duration_seconds_count[5m]))", "legendFormat": "req/s"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "percentunit", "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "5xx Error Rate",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum(rate(frostgate_http_5xx_total[5m])) / (sum(rate(frostgate_http_request_duration_seconds_count[5m])) + 0.001)", "legendFormat": "5xx rate"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"steps": [{"color": "green"}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "p99 Request Latency",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "histogram_quantile(0.99, sum by (le) (rate(frostgate_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "histogram_quantile(0.50, sum by (le) (rate(frostgate_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(frostgate_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "histogram_quantile(0.99, sum by (le) (rate(frostgate_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 11,
      "title": "HTTP Status Class Rates",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum by (status_class) (rate(frostgate_http_request_duration_seconds_count[5m]))", "legendFormat": "{{ status_class }}"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "Database",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green"}, {"color": "red", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 14},
      "id": 20,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "DB Connectivity Failures (5m)",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "increase(frostgate_db_connectivity_failures_total[5m])", "legendFormat": "failures"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 14},
      "id": 21,
      "title": "DB Error Rate by Operation",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum by (operation) (rate(frostgate_db_errors_total[5m]))", "legendFormat": "{{ operation }}"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["frostgate", "system"],
  "templating": {
    "list": [
      {"current": {}, "hide": 0, "includeAll": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "FrostGate — System Health",
  "uid": "fg-system-health",
  "version": 1
}
